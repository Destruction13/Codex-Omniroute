<views:PageBase
    x:Class="OmniRouteInstaller.Views.CredentialsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:OmniRouteInstaller.Views"
    Title="OmniRoute Credentials">

    <Grid Margin="48,28,48,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Подключение к OmniRoute" Style="{StaticResource TitleText}" />
            <TextBlock Margin="0,12,0,0"
                       Style="{StaticResource SubtitleText}"
                       Text="Эти значения уйдут в omniroute-provider.json в распакованной папке. Файл в .gitignore и не покидает машину." />
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource LabelText}" Text="BASE URL" />
                    <TextBox x:Name="BaseUrlBox"
                             Margin="0,8,0,0"
                             Style="{StaticResource InputText}" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource CaptionText}"
                               Text="Например: https://omni.example.com/v1" />

                    <TextBlock Margin="0,22,0,0" Style="{StaticResource LabelText}" Text="API KEY" />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="ApiKeyPwd"
                                     Grid.Column="0"
                                     Style="{StaticResource InputPassword}"
                                     PasswordChanged="ApiKeyPwd_PasswordChanged" />
                        <TextBox x:Name="ApiKeyPlain"
                                 Grid.Column="0"
                                 Style="{StaticResource InputText}"
                                 Visibility="Collapsed"
                                 TextChanged="ApiKeyPlain_TextChanged" />
                        <Button Grid.Column="1"
                                Margin="10,0,0,0"
                                Style="{StaticResource SecondaryButton}"
                                Content="Показать"
                                x:Name="ToggleApiKey"
                                Click="ToggleApiKey_Click"
                                MinWidth="110" />
                    </Grid>
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource CaptionText}"
                               Text="Главный ключ для reasoning-эндпоинтов." />

                    <Expander Margin="0,22,0,0"
                              Foreground="{StaticResource TextSecondary}"
                              Header="Дополнительный ключ для картинок (опционально)">
                        <StackPanel Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="ImageKeyPwd"
                                             Grid.Column="0"
                                             Style="{StaticResource InputPassword}"
                                             PasswordChanged="ImageKeyPwd_PasswordChanged" />
                                <TextBox x:Name="ImageKeyPlain"
                                         Grid.Column="0"
                                         Style="{StaticResource InputText}"
                                         Visibility="Collapsed"
                                         TextChanged="ImageKeyPlain_TextChanged" />
                                <Button Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource SecondaryButton}"
                                        Content="Показать"
                                        x:Name="ToggleImageKey"
                                        Click="ToggleImageKey_Click"
                                        MinWidth="110" />
                            </Grid>
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource CaptionText}"
                                       Text="Если пусто — bridge будет использовать тот же api_key для image-пайплайна." />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Button HorizontalAlignment="Left"
                    Style="{StaticResource SecondaryButton}"
                    Content="← Назад"
                    Click="Back_Click" />
            <Button HorizontalAlignment="Right"
                    Style="{StaticResource PrimaryButton}"
                    Content="Продолжить →"
                    Click="Continue_Click" />
        </Grid>
    </Grid>
</views:PageBase>
