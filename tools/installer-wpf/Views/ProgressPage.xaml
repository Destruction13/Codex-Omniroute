<views:PageBase
    x:Class="OmniRouteInstaller.Views.ProgressPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:OmniRouteInstaller.Views"
    Title="Installing">

    <Grid Margin="48,28,48,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="HeaderText" Text="Устанавливаем…" Style="{StaticResource TitleText}" />
            <TextBlock x:Name="SubHeaderText"
                       Margin="0,12,0,0"
                       Style="{StaticResource SubtitleText}"
                       Text="Можно свернуть окно. Я допишу прогресс, когда закончу." />
        </StackPanel>

        <!-- Steps list -->
        <ItemsControl x:Name="StepsList"
                      Grid.Row="1"
                      Margin="0,22,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="22" Height="22"
                                CornerRadius="11"
                                Background="{Binding StatusBg}"
                                BorderBrush="{Binding StatusBorder}"
                                BorderThickness="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                            <TextBlock Text="{Binding StatusGlyph}"
                                       FontFamily="{StaticResource UiFont}"
                                       FontSize="12"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Column="1"
                                   Margin="14,0,0,0"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource UiFont}"
                                   FontSize="14"
                                   Foreground="{Binding StatusText}"
                                   Text="{Binding Title}" />

                        <TextBlock Grid.Column="2"
                                   Margin="0,0,0,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CaptionText}"
                                   Text="{Binding Detail}" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Log -->
        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="12">
            <ScrollViewer x:Name="LogScroller"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16,12">
                <TextBox x:Name="LogBox"
                         FontFamily="{StaticResource MonoFont}"
                         FontSize="11"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource TextMuted}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap" />
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Button x:Name="ToggleLogButton"
                    HorizontalAlignment="Left"
                    Style="{StaticResource SecondaryButton}"
                    Content="Скрыть лог"
                    Click="ToggleLog_Click"
                    MinWidth="120" />
            <Button x:Name="ContinueButton"
                    HorizontalAlignment="Right"
                    Style="{StaticResource PrimaryButton}"
                    Content="Готово →"
                    Click="Continue_Click"
                    IsEnabled="False" />
        </Grid>
    </Grid>
</views:PageBase>
