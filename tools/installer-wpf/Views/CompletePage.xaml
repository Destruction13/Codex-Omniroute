<views:PageBase
    x:Class="OmniRouteInstaller.Views.CompletePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:OmniRouteInstaller.Views"
    Title="Done">

    <Grid Margin="48,32,48,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center">
            <Border Width="84" Height="84"
                    CornerRadius="20"
                    Background="{StaticResource AccentGradient}"
                    HorizontalAlignment="Left">
                <Border.Effect>
                    <DropShadowEffect Color="#FF8B5CF6" BlurRadius="38" ShadowDepth="0" Opacity="0.45" />
                </Border.Effect>
                <Path Data="M14,32 L28,46 L54,18"
                      Stroke="White"
                      StrokeThickness="6"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Stretch="Uniform"
                      Width="44" Height="44" />
            </Border>

            <TextBlock Margin="0,28,0,0" Text="Codex OmniRoute установлен" Style="{StaticResource TitleText}" />
            <TextBlock x:Name="PathLabel"
                       Margin="0,12,0,0"
                       Style="{StaticResource SubtitleText}" />

            <Border Style="{StaticResource Card}" Margin="0,28,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource LabelText}" Text="ДАЛЬШЕ" />
                    <TextBlock Margin="0,10,0,0" Style="{StaticResource BodyText}">
                        <Run Text="•" Foreground="{StaticResource Accent}" /> <Run Text="Codex OmniRoute и Codex Official — на рабочем столе и в Start Menu" />
                        <LineBreak />
                        <Run Text="•" Foreground="{StaticResource Accent}" /> <Run Text="При первом запуске Codex попросит зайти в твой аккаунт OpenAI" />
                        <LineBreak />
                        <Run Text="•" Foreground="{StaticResource Accent}" /> <Run Text="Проверить здоровье bridge:" /> <Run FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextPrimary}" Text="Invoke-RestMethod http://127.0.0.1:20333/healthz" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource SecondaryButton}"
                    Content="Открыть папку"
                    Click="OpenFolder_Click"
                    MinWidth="160" />

            <Button Grid.Column="2"
                    Margin="0,0,10,0"
                    Style="{StaticResource SecondaryButton}"
                    Content="Закрыть"
                    Click="Close_Click" />

            <Button Grid.Column="3"
                    Style="{StaticResource PrimaryButton}"
                    Content="Запустить Codex OmniRoute"
                    Click="Launch_Click" />
        </Grid>
    </Grid>
</views:PageBase>
