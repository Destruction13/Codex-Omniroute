<views:PageBase
    x:Class="OmniRouteInstaller.Views.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:OmniRouteInstaller.Views"
    Title="Welcome">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Hero panel with gradient -->
        <Border Grid.Column="0"
                Background="{StaticResource HeroGradient}"
                CornerRadius="0,0,0,0">
            <Grid>
                <!-- Decorative orbs -->
                <Ellipse Width="320" Height="320"
                         Fill="#33A78BFA"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top"
                         Margin="-100,-80,0,0" />
                <Ellipse Width="240" Height="240"
                         Fill="#22FFFFFF"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Bottom"
                         Margin="0,0,-60,-60" />

                <StackPanel VerticalAlignment="Center" Margin="36,0,36,0">
                    <Border Width="92" Height="92"
                            CornerRadius="22"
                            Background="#FFFFFFFF"
                            HorizontalAlignment="Left">
                        <Border.Effect>
                            <DropShadowEffect Color="#FF1E1B4B" BlurRadius="40" ShadowDepth="0" Opacity="0.5" />
                        </Border.Effect>
                        <Path Data="M22,16 L34,28 L34,52 L46,52 L46,28 L58,16 L70,28 L70,52 L46,80 L22,52 Z"
                              Fill="{StaticResource AccentGradient}"
                              Stretch="Uniform"
                              Width="56" Height="56" />
                    </Border>

                    <TextBlock Text="Codex OmniRoute"
                               FontFamily="{StaticResource UiFont}"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,28,0,4" />
                    <TextBlock Text="Setup Wizard"
                               FontFamily="{StaticResource UiFont}"
                               FontSize="15"
                               Foreground="#FFCBD5E1"
                               Margin="0,0,0,28" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Ellipse Width="6" Height="6" Fill="#FF8B5CF6" VerticalAlignment="Center" />
                        <TextBlock Text="Один общий %USERPROFILE%\.codex"
                                   FontSize="12"
                                   Foreground="#FFE9D5FF"
                                   Margin="10,0,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Ellipse Width="6" Height="6" Fill="#FF8B5CF6" VerticalAlignment="Center" />
                        <TextBlock Text="Reasoning через твой OmniRoute"
                                   FontSize="12"
                                   Foreground="#FFE9D5FF"
                                   Margin="10,0,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Ellipse Width="6" Height="6" Fill="#FF8B5CF6" VerticalAlignment="Center" />
                        <TextBlock Text="Голос, Compact, MCP и плагины — нативные"
                                   FontSize="12"
                                   Foreground="#FFE9D5FF"
                                   Margin="10,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1" Margin="48,32,48,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Center">
                <TextBlock Text="Добро пожаловать" Style="{StaticResource TitleText}" />
                <TextBlock Margin="0,16,0,0" Style="{StaticResource SubtitleText}"
                           Text="Этот установщик подготовит твой Windows под Codex OmniRoute — официальный OpenAI Codex Desktop, в котором reasoning идёт через твой собственный OmniRoute-провайдер. Без расхода ChatGPT-квоты и без потери голоса, Compact, MCP и плагинов." />

                <Border Style="{StaticResource Card}" Margin="0,28,0,0" Padding="20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelText}" Text="ЧТО ПРОИЗОЙДЁТ" />
                        <TextBlock Margin="0,10,0,0" Style="{StaticResource BodyText}">
                            <Run Text="•" Foreground="{StaticResource Accent}" /> <Run Text="Распакую Codex OmniRoute в выбранную папку" />
                            <LineBreak />
                            <Run Text="•" Foreground="{StaticResource Accent}" /> <Run Text="Установлю Node.js, .NET SDK и OpenAI Codex Desktop через" /> <Run FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextPrimary}" Text="winget" />
                            <LineBreak />
                            <Run Text="•" Foreground="{StaticResource Accent}" /> <Run Text="Запишу твои base_url и api_key в провайдер-файл" />
                            <LineBreak />
                            <Run Text="•" Foreground="{StaticResource Accent}" /> <Run Text="Создам ярлыки Codex OmniRoute и Codex Official на рабочем столе" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Bottom buttons -->
            <Grid Grid.Row="1" Margin="0,24,0,0">
                <Button HorizontalAlignment="Left"
                        Style="{StaticResource LinkButton}"
                        Content="github.com/Destruction13/Codex-Omniroute ↗"
                        Click="OpenRepo_Click" />
                <Button HorizontalAlignment="Right"
                        Style="{StaticResource PrimaryButton}"
                        Content="Начать установку →"
                        Click="Continue_Click" />
            </Grid>
        </Grid>
    </Grid>
</views:PageBase>
