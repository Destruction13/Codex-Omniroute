# Codex OmniRoute — never commit runtime/auth state

# Variant-3 isolated CODEX_HOME (seeded by Start-Codex-OmniRoute.ps1 at
# every launch; deleted by Start-Codex-OmniRoute.ps1 -Restore). Contains
# a copy of the user's auth.json -- never commit.
.codex-omniroute-home/
.codex-omniroute-home-*/

# Bridge runtime artifacts
bridge.pid
bridge.log
*.pid
*.log
*.log.*
*.bak
*.backup

# Local provider config (real secrets live here)
omniroute-provider.json
codex-omniroute-config-overlay.toml
.env
.env.*
!.env.example

# Official Codex auth or profile fragments accidentally copied in
auth.json
auth.json.bak
models_cache.json
installation_id
sessions/
threads/
history/
storage/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Optional helper output
tools/__pycache__/
*.pyc
mock-transcribe-upstream.log
