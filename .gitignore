# Codex OmniRoute — never commit runtime/auth state

# Legacy isolated CODEX_HOME from pre-shared-home builds. It is no longer an
# active runtime home, but may exist on upgraded machines and can contain
# copied auth/session state -- never commit it.
.codex-omniroute-home/
.codex-omniroute-home-*/

# Bridge runtime artifacts
bridge.pid
bridge.log
*.pid
*.log
*.log.*
*.bak
*.backup

# Local provider config (real secrets live here)
omniroute-provider.json
codex-omniroute-config-overlay.toml
.env
.env.*
!.env.example

# Official Codex auth or profile fragments accidentally copied in
auth.json
auth.json.bak
models_cache.json
installation_id
sessions/
threads/
history/
storage/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Optional helper output
tools/__pycache__/
*.pyc
mock-transcribe-upstream.log
.setup-bootstrapper-build/

# OmniRoute MCP/skills catalog cache (last-known-good copy of the remote
# catalog; refreshed by tools/omniroute-catalog.mjs on every launch when
# OMNIROUTE_CATALOG_URL is set). Never commit -- the in-repo bundle
# default-mcp-catalog.json is the only catalog tracked in git.
.codex-omniroute-catalog-cache.json
