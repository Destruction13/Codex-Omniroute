# Codex OmniRoute — example env. Copy to .env and source via your launcher if desired.
# Never commit the populated .env file.

# --- OmniRoute (main reasoning target) ---
# Either OMNIROUTE_BASE_URL+OMNIROUTE_API_KEY, OR a local omniroute-provider.json, OR an OpenCode-style provider config.
OMNIROUTE_BASE_URL=http://127.0.0.1:20128/v1
OMNIROUTE_API_KEY=

# Prefix applied to model names sent to OmniRoute (e.g. gpt-5.4 -> cx/gpt-5.4).
OMNIROUTE_MODEL_PREFIX=cx/

# Optional JSON map applied before prefixing. This makes Codex's GPT-5.5
# selector hit OmniRoute's explicit xhigh model while GPT-5.4 stays unchanged.
OMNIROUTE_MODEL_ALIASES={"gpt-5.5":"gpt-5.5-xhigh"}

# Optional: pin GPT-5.5 routing. Disabled unless OMNIROUTE_PIN_55=1.
OMNIROUTE_PIN_55=0
OMNIROUTE_55_CONNECTION_ID=

# --- Official Codex upstream (compact, dictation, account, MCP backends, ...) ---
# The bridge proxies anything that is NOT main reasoning to this base URL.
# Default reflects the URL Codex desktop talks to. Adjust if your install differs.
CODEX_OFFICIAL_UPSTREAM=https://chatgpt.com/backend-api/codex

# --- Bridge ---
# Used when running the bridge manually. The launcher uses -BridgePort and
# passes these values to the bridge process itself.
CODEX_BRIDGE_HOST=127.0.0.1
CODEX_BRIDGE_PORT=20333

# Optional bridge logging.
# The launcher writes bridge.pid itself and passes BRIDGE_LOG_PATH=bridge.log
# to the bridge. Set BRIDGE_LOG_PATH only when running the bridge manually.
BRIDGE_LOG_PATH=bridge.log
