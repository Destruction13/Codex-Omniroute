# Codex OmniRoute — example env. Copy to .env and source via your launcher if desired.
# Never commit the populated .env file.

# --- OmniRoute (main reasoning target) ---
# Either OMNIROUTE_BASE_URL+OMNIROUTE_API_KEY, OR a local omniroute-provider.json, OR an OpenCode-style provider config.
OMNIROUTE_BASE_URL=http://127.0.0.1:20128/v1
OMNIROUTE_API_KEY=

# Prefix applied to model names sent to OmniRoute (e.g. gpt-5.4 -> cx/gpt-5.4).
OMNIROUTE_MODEL_PREFIX=cx/

# Optional JSON map applied before prefixing. This makes Codex's GPT-5.5
# selector hit OmniRoute's explicit xhigh model.
OMNIROUTE_MODEL_ALIASES={"gpt-5.5":"gpt-5.5-xhigh"}

# --- OmniRoute image lane ---
# If unset, the bridge falls back to the main provider key. Set a dedicated key
# when your OmniRoute image gateway uses a separate credential.
CODEX_OMNI_OMNIROUTE_IMAGE_API_KEY=
CODEX_OMNI_OMNIROUTE_IMAGE_MODEL=chatgpt-web/gpt-5.3-instant

# OmniRoute-compatible upstreams often reject bodies above 10MB. The bridge
# keeps recent inline images, caches omitted older images locally, and replaces
# old inline image payloads with text placeholders before forwarding.
CODEX_OMNI_OMNIROUTE_MAX_BODY_BYTES=10485760
CODEX_OMNI_INLINE_IMAGE_HISTORY_BUDGET_BYTES=6291456

# Optional: pin GPT-5.5 routing. Disabled unless OMNIROUTE_PIN_55=1.
OMNIROUTE_PIN_55=0
OMNIROUTE_55_CONNECTION_ID=

# --- Official Codex upstream (compact, dictation, account, MCP backends, ...) ---
# The bridge proxies anything that is NOT main reasoning to this base URL.
# Default reflects the URL Codex desktop talks to. Adjust if your install differs.
CODEX_OFFICIAL_UPSTREAM=https://chatgpt.com/backend-api/codex

# --- Bridge ---
# Used when running the bridge manually. The launcher uses -BridgePort and
# passes these values to the bridge process itself.
CODEX_BRIDGE_HOST=127.0.0.1
CODEX_BRIDGE_PORT=20333

# Optional bridge logging.
# The launcher writes bridge.pid itself and passes BRIDGE_LOG_PATH=bridge.log
# to the bridge. Set BRIDGE_LOG_PATH only when running the bridge manually.
BRIDGE_LOG_PATH=bridge.log

# --- OmniRoute MCP / skills catalog (legacy/opt-in) ---
# The shared-home gateway does not import MCP config into a separate profile.
# Native MCP/plugin config stays in %USERPROFILE%\.codex\config.toml. Keep this
# disabled unless you intentionally use the catalog helper to write safe helper
# marketplace/plugin sections into the shared home.
OMNIROUTE_CATALOG_ENABLED=0
OMNIROUTE_CATALOG_URL=

# Set to 1 to force-disable the catalog helper, even if ENABLED or URL is set.
OMNIROUTE_CATALOG_DISABLED=0

# --- API keys for opt-in catalog/overlay MCPs (every user supplies their own) ---
# Only fill these when your managed catalog or codex-omniroute-config-overlay.toml
# references the variables. Nothing here is shared between users and nothing
# leaks into the repo.

# Mem0 personal-memory MCP -- https://app.mem0.ai/dashboard/api-keys
MEM0_API_KEY=

# Official GitHub MCP. Fine-grained tokens recommended.
# https://github.com/settings/tokens?type=beta
GITHUB_PERSONAL_ACCESS_TOKEN=

# Wildcard DeepContext MCP -- https://wildcard.ai dashboard
WILDCARD_API_KEY=

# 21st-dev Magic frontend MCP -- https://21st.dev/magic console
TWENTY_FIRST_API_KEY=

# RoxyBrowser OpenAPI MCP. The host defaults to http://127.0.0.1:50000 if
# unset; set ROXY_API_HOST only if your RoxyBrowser desktop app listens on
# a different port. ROXY_API_KEY is required and comes from the
# RoxyBrowser app: Settings -> API.
ROXY_API_HOST=
ROXY_API_KEY=

# ref.tools hosted MCP -- https://ref.tools dashboard
REF_TOOLS_API_KEY=

# Pipedream MCP.
# Consumer/OAuth mode uses the static endpoint in codex-omniroute-config-overlay.toml:
#   https://mcp.pipedream.net/v2
# Developer/v3 mode requires an access token plus x-pd-* request headers:
#   https://remote.mcp.pipedream.net/v3
# Fill these and use ${VAR} placeholders in your local overlay if you want
# mcp_probe to list/call Pipedream tools without an interactive OAuth client.
PIPEDREAM_MCP_URL=https://remote.mcp.pipedream.net/v3
PIPEDREAM_MCP_ACCESS_TOKEN=
PIPEDREAM_PROJECT_ID=
PIPEDREAM_ENVIRONMENT=development
PIPEDREAM_EXTERNAL_USER_ID=
PIPEDREAM_APP_SLUG=
